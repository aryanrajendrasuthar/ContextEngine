{
  "title": "ContextEngine Operations",
  "uid": "contextengine-ops",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "tags": ["contextengine", "production"],
  "panels": [
    {
      "id": 1,
      "title": "Query Throughput (req/min)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{job=\"contextengine-query-service\",uri=\"/api/v1/query\"}[1m]) * 60",
          "legendFormat": "Queries / min"
        }
      ]
    },
    {
      "id": 2,
      "title": "Query Latency Percentiles",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(http_server_requests_seconds_bucket{job=\"contextengine-query-service\",uri=\"/api/v1/query\"}[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(http_server_requests_seconds_bucket{job=\"contextengine-query-service\",uri=\"/api/v1/query\"}[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(http_server_requests_seconds_bucket{job=\"contextengine-query-service\",uri=\"/api/v1/query\"}[5m]))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 3,
      "title": "Cache Hit Rate",
      "type": "gauge",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0, "max": 1,
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 0.3 },
              { "color": "green", "value": 0.6 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"contextengine-query-service\",uri=\"/api/v1/query\",outcome=\"SUCCESS\"}[5m])) / sum(rate(http_server_requests_seconds_count{job=\"contextengine-query-service\",uri=\"/api/v1/query\"}[5m]))",
          "legendFormat": "Cache Hit Rate"
        }
      ]
    },
    {
      "id": 4,
      "title": "Kafka Consumer Lag — Embedding Service",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "kafka_consumer_fetch_manager_records_lag_max{client_id=\"embedding-service\"}",
          "legendFormat": "Max Lag"
        }
      ]
    },
    {
      "id": 5,
      "title": "Ingestion Throughput (events/min)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{job=\"contextengine-ingestion-service\",uri=\"/api/v1/events/ingest\",status=\"201\"}[1m]) * 60",
          "legendFormat": "Events ingested / min"
        }
      ]
    },
    {
      "id": 6,
      "title": "Service Error Rates (5xx / min)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{job=~\"contextengine-.*\",status=~\"5..\"}[1m]) * 60",
          "legendFormat": "{{ job }}"
        }
      ]
    },
    {
      "id": 7,
      "title": "JVM Heap Usage",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{area=\"heap\",job=~\"contextengine-.*\"}",
          "legendFormat": "{{ job }}"
        }
      ]
    },
    {
      "id": 8,
      "title": "Rate Limit Rejections (429/min)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 24, "w": 8, "h": 6 },
      "targets": [
        {
          "expr": "rate(spring_cloud_gateway_requests_seconds_count{status=\"429\"}[1m]) * 60",
          "legendFormat": "429s / min"
        }
      ]
    },
    {
      "id": 9,
      "title": "Active Pods per Service",
      "type": "stat",
      "gridPos": { "x": 8, "y": 24, "w": 16, "h": 6 },
      "targets": [
        {
          "expr": "kube_deployment_status_replicas_available{namespace=\"contextengine\"}",
          "legendFormat": "{{ deployment }}"
        }
      ]
    }
  ]
}
